{
    "name": "inclusive-elements",
    "version": "0.6.1",
    "description": "Accessible, lightweight, unstyled implementations of UI patterns that still need runtime help.",
    "type": "module",
    "module": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "license": "MIT",
    "repository": "tobyzerner/inclusive-elements",
    "files": [
        "dist",
        "CHANGELOG.md",
        "src/*/README.md"
    ],
    "sideEffects": false,
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && vite build && tsc --emitDeclarationOnly",
        "prepare": "pnpm build",
        "test": "vitest run",
        "preview": "vite preview",
        "release": "release-it"
    },
    "dependencies": {
        "tabbable": "^6.4.0",
        "transition-kit": "^1.0.0"
    },
    "devDependencies": {
        "@release-it/conventional-changelog": "^5.1.1",
        "jsdom": "^29.0.1",
        "prettier": "^2.8.8",
        "release-it": "^15.11.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.1",
        "vitest": "^4.1.0"
    },
    "release-it": {
        "git": {
            "commitMessage": "release: v${version}",
            "tagName": "v${version}"
        },
        "github": {
            "release": true,
            "releaseName": "v${version}"
        },
        "plugins": {
            "@release-it/conventional-changelog": {
                "preset": "conventionalcommits",
                "infile": "CHANGELOG.md",
                "header": "# Changelog"
            }
        }
    },
    "prettier": {
        "singleQuote": true
    },
    "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}
